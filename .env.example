# ========== 数据库 ==========
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=sync_manager

# ========== Redis ==========
REDIS_PORT=6379

# ========== JWT ==========
JWT_SECRET=sync-manager-jwt-secret-key-2026-must-be-at-least-256-bits

# ========== 后端 ==========
BACKEND_PORT=8080
STORAGE_PATH=/data/file-sync
SYNC_MODE=FULL
TEST_ENABLED=false
TEST_MAX_FILES=999999

# ========== 磁盘告警阈值 ==========
DISK_WARNING_THRESHOLD=0.8
DISK_SEVERE_THRESHOLD=0.9
DISK_STOP_THRESHOLD=0.95

# ========== 前端 ==========
FRONTEND_PORT=80
